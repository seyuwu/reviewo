{
  "name": "@reviewo/api",
  "version": "0.0.0",
  "private": true,
  "description": "Reviewo backend API application.",
  "type": "module",
  "main": "./dist/main.js",
  "imports": {
    "#prisma/client": "./dist/generated/prisma/client.js"
  },
  "scripts": {
    "build": "corepack pnpm db:generate && tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "dev": "corepack pnpm build && node dist/main.js",
    "lint": "eslint .",
    "reputation:backfill": "corepack pnpm build && node dist/scripts/reputation-backfill.js",
    "reputation:replay": "corepack pnpm build && node dist/scripts/reputation-replay.js",
    "start": "node dist/main.js",
    "start:prod": "corepack pnpm db:migrate && node dist/main.js",
    "test": "corepack pnpm build && node scripts/run-tests.mjs",
    "typecheck": "corepack pnpm db:generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/websockets": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "helmet": "^8.2.0",
    "pg": "^8.22.0",
    "redis": "^5.10.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
