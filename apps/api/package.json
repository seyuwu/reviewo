{
  "name": "@reviewo/api",
  "version": "0.0.0",
  "private": true,
  "description": "Reviewo backend API application.",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "corepack pnpm db:generate && tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "dev": "corepack pnpm build && node dist/main.js",
    "lint": "eslint .",
    "start": "node dist/main.js",
    "test": "corepack pnpm build && node --test dist/modules/entities/services/lazy-entity-title.test.js dist/modules/entities/services/ensure-entity-for-url.test.js dist/modules/entities/services/entity-visibility.test.js dist/modules/extension-api/use-cases/rate-site.use-case.test.js dist/modules/extension-api/controllers/extension-api.auth.test.js dist/modules/moderation/controllers/moderation.auth.test.js",
    "typecheck": "corepack pnpm db:generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0"
  }
}
