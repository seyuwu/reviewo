model TopCategory {
  id        String @id @default(uuid()) @db.Uuid
  slug      String @unique
  title     String
  sortOrder Int    @map("sort_order")
  tops      Top[]

  @@map("top_categories")
  @@schema("tops")
}

model Top {
  id            String            @id @default(uuid()) @db.Uuid
  slug          String            @unique
  title         String
  description   String?
  locale        String            @default("ru")
  authorId      String            @map("author_id") @db.Uuid
  categoryId    String?           @map("category_id") @db.Uuid
  forkedFromId  String?           @map("forked_from_id") @db.Uuid
  visibility    TopVisibility     @default(ACTIVE)
  rankMode      TopRankMode       @default(MANUAL) @map("rank_mode")
  systemSortKey TopSystemSortKey? @map("system_sort_key")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  category      TopCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  forkedFrom    Top?              @relation("TopForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks         Top[]             @relation("TopForks")
  items         TopItem[]
  likes         TopLike[]
  views         TopView[]
  comments      TopComment[]

  @@index([authorId])
  @@index([categoryId])
  @@index([forkedFromId])
  @@index([visibility])
  @@index([rankMode])
  @@index([locale, createdAt])
  @@map("tops")
  @@schema("tops")
}

model TopItem {
  id        String   @id @default(uuid()) @db.Uuid
  topId     String   @map("top_id") @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  position  Int
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  top       Top      @relation(fields: [topId], references: [id], onDelete: Cascade)

  @@unique([topId, entityId])
  @@unique([topId, position])
  @@index([entityId])
  @@map("top_items")
  @@schema("tops")
}

model TopLike {
  id        String   @id @default(uuid()) @db.Uuid
  topId     String   @map("top_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
