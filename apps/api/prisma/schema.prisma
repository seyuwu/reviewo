generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "chat", "entities", "ratings", "reviews", "users", "reputation"]
}

model User {
  id             String             @id @default(uuid()) @db.Uuid
  email          String?            @unique
  username       String?            @unique
  displayName    String             @map("display_name")
  avatarUrl      String?            @map("avatar_url")
  role           UserRole           @default(USER)
  status         String             @default("active")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  authIdentities     UserAuthIdentity[]
  entityChatMessages EntityChatMessage[]

  @@map("users")
  @@schema("users")
}

enum UserRole {
  USER
  ADMIN

  @@map("user_role")
  @@schema("users")
}

model UserAuthIdentity {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String
  providerUserId String   @map("provider_user_id")
  passwordHash   String?  @map("password_hash")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("user_auth_identities")
  @@schema("auth")
}

enum EntityType {
  website
  page
  video
  channel
  repository
  organization
  product
  book
  movie
  game
  company
  person
  place
  other

  @@map("entity_type")
  @@schema("entities")
}

enum EntityVisibility {
  ACTIVE
  HIDDEN

  @@map("entity_visibility")
  @@schema("entities")
}

model Entity {
  id           String           @id @default(uuid()) @db.Uuid
  title        String
  slug         String           @unique
  type         EntityType
  visibility   EntityVisibility @default(ACTIVE)
  description  String?
  canonicalUrl String?          @unique @map("canonical_url")
  parentId     String?          @map("parent_id") @db.Uuid
  createdBy    String?          @map("created_by") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  parent       Entity?          @relation("EntityTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Entity[]         @relation("EntityTree")

  @@index([type])
  @@index([parentId])
  @@index([createdBy])
  @@index([visibility])
  @@map("entities")
  @@schema("entities")
}

model Rating {
  id        String   @id @default(uuid()) @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  score     Int      @db.SmallInt
  source    String   @default("web")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([entityId, userId])
  @@index([entityId])
  @@index([userId])
  @@map("ratings")
  @@schema("ratings")
}

model RatingAggregate {
  entityId      String   @id @map("entity_id") @db.Uuid
  avgScore      Decimal  @default(0) @map("avg_score") @db.Decimal(3, 2)
  votesCount    Int      @default(0) @map("votes_count")
  distribution1 Int      @default(0) @map("distribution_1")
  distribution2 Int      @default(0) @map("distribution_2")
  distribution3 Int      @default(0) @map("distribution_3")
  distribution4 Int      @default(0) @map("distribution_4")
  distribution5 Int      @default(0) @map("distribution_5")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("rating_aggregates")
  @@schema("ratings")
}

enum ReviewVisibility {
  ACTIVE
  HIDDEN

  @@map("review_visibility")
  @@schema("reviews")
}

model Review {
  id         String           @id @default(uuid()) @db.Uuid
  entityId   String           @map("entity_id") @db.Uuid
  authorId   String           @map("author_id") @db.Uuid
  text       String
  visibility ReviewVisibility @default(ACTIVE)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  votes      ReviewVote[]

  @@unique([authorId, entityId])
  @@index([entityId])
  @@index([authorId])
  @@index([visibility])
  @@map("reviews")
  @@schema("reviews")
}

model ReviewVote {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @map("review_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
  @@map("review_votes")
  @@schema("reviews")
}

model UserBehaviorMetrics {
  userId                String    @id @map("user_id") @db.Uuid
  totalRatings          Int       @default(0) @map("total_ratings")
  uniqueEntityCount     Int       @default(0) @map("unique_entity_count")
  uniqueEntityTypeCount Int       @default(0) @map("unique_entity_type_count")
  uniqueRootDomainCount Int       @default(0) @map("unique_root_domain_count")
  score1Count           Int       @default(0) @map("score_1_count")
  score2Count           Int       @default(0) @map("score_2_count")
  score3Count           Int       @default(0) @map("score_3_count")
  score4Count           Int       @default(0) @map("score_4_count")
  score5Count           Int       @default(0) @map("score_5_count")
  firstRatingAt         DateTime? @map("first_rating_at") @db.Timestamptz(6)
  lastRatingAt          DateTime? @map("last_rating_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("user_behavior_metrics")
  @@schema("reputation")
}

model UserActivityDaily {
  userId       String   @map("user_id") @db.Uuid
  activityDate DateTime @map("activity_date") @db.Date
  ratingCount  Int      @default(0) @map("rating_count")

  @@id([userId, activityDate])
  @@index([userId, activityDate(sort: Desc)])
  @@map("user_activity_daily")
  @@schema("reputation")
}

model UserEntityStats {
  userId      String   @map("user_id") @db.Uuid
  entityId    String   @map("entity_id") @db.Uuid
  ratingCount Int      @default(0) @map("rating_count")
  lastRatedAt DateTime @map("last_rated_at") @db.Timestamptz(6)

  @@id([userId, entityId])
  @@index([userId, ratingCount(sort: Desc)])
  @@map("user_entity_stats")
  @@schema("reputation")
}

model UserEntityTypeStats {
  userId            String @map("user_id") @db.Uuid
  entityType        String @map("entity_type")
  parentContextType String @default("__root__") @map("parent_context_type")
  ratingCount       Int    @default(0) @map("rating_count")

  @@id([userId, entityType, parentContextType])
  @@map("user_entity_type_stats")
  @@schema("reputation")
}

model UserRootDomainStats {
  userId      String @map("user_id") @db.Uuid
  rootDomain  String @map("root_domain")
  ratingCount Int    @default(0) @map("rating_count")

  @@id([userId, rootDomain])
  @@map("user_root_domain_stats")
  @@schema("reputation")
}

model UserTrustProfile {
  userId             String   @id @map("user_id") @db.Uuid
  trustScore         Decimal  @map("trust_score") @db.Decimal(4, 3)
  diversityScore     Decimal  @map("diversity_score") @db.Decimal(4, 3)
  coverageScore      Decimal  @map("coverage_score") @db.Decimal(4, 3)
  stabilityScore     Decimal  @map("stability_score") @db.Decimal(4, 3)
  consensusScore     Decimal  @map("consensus_score") @db.Decimal(4, 3)
  accountAgeBonus    Decimal  @map("account_age_bonus") @db.Decimal(4, 3)
  anomalyPenalty     Decimal  @default(0) @map("anomaly_penalty") @db.Decimal(4, 3)
  calculationVersion Int      @map("calculation_version")
  calculatedAt       DateTime @map("calculated_at") @db.Timestamptz(6)

  @@map("user_trust_profiles")
  @@schema("reputation")
}

model VoteWeightSnapshot {
  id                 String   @id @default(uuid()) @db.Uuid
  ratingId           String   @unique @map("rating_id") @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  entityId           String   @map("entity_id") @db.Uuid
  score              Int      @db.SmallInt
  voteWeight         Decimal  @map("vote_weight") @db.Decimal(4, 3)
  weightFactors      Json     @default("{}") @map("weight_factors")
  calculationVersion Int      @map("calculation_version")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityId])
  @@index([userId])
  @@map("vote_weight_snapshots")
  @@schema("reputation")
}

model EntityAnomalyMetrics {
  entityId         String    @id @map("entity_id") @db.Uuid
  anomalyScore     Decimal   @default(0) @map("anomaly_score") @db.Decimal(4, 3)
  burstScore       Decimal   @default(0) @map("burst_score") @db.Decimal(4, 3)
  syncScore        Decimal   @default(0) @map("sync_score") @db.Decimal(4, 3)
  clusterScore     Decimal   @default(0) @map("cluster_score") @db.Decimal(4, 3)
  recentBurstCount Int       @default(0) @map("recent_burst_count")
  lastAnomalyAt    DateTime? @map("last_anomaly_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("entity_anomaly_metrics")
  @@schema("reputation")
}

model EntityActivityHourly {
  entityId     String   @map("entity_id") @db.Uuid
  activityHour DateTime @map("activity_hour") @db.Timestamptz(6)
  ratingCount  Int      @default(0) @map("rating_count")

  @@id([entityId, activityHour])
  @@map("entity_activity_hourly")
  @@schema("reputation")
}

model EntityConfidenceProfile {
  entityId             String   @id @map("entity_id") @db.Uuid
  confidenceScore      Decimal  @map("confidence_score") @db.Decimal(4, 3)
  effectiveVoteMass    Decimal  @default(0) @map("effective_vote_mass") @db.Decimal(10, 2)
  uniqueRatersCount    Int      @default(0) @map("unique_raters_count")
  activityDurationDays Int      @default(0) @map("activity_duration_days")
  scoreVariance        Decimal? @map("score_variance") @db.Decimal(6, 4)
  anomalyScore         Decimal  @default(0) @map("anomaly_score") @db.Decimal(4, 3)
  calculationVersion   Int      @map("calculation_version")
  explanation          Json     @default("[]")
  calculatedAt         DateTime @map("calculated_at") @db.Timestamptz(6)

  @@map("entity_confidence_profiles")
  @@schema("reputation")
}

model ReputationEvent {
  id        String   @id @default(uuid()) @db.Uuid
  type      String
  userId    String?  @map("user_id") @db.Uuid
  entityId  String?  @map("entity_id") @db.Uuid
  ratingId  String?  @map("rating_id") @db.Uuid
  payload   Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([entityId, createdAt])
  @@index([type, createdAt])
  @@map("reputation_events")
  @@schema("reputation")
}

model EntityChatMessage {
  id           String   @id @default(uuid()) @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  message      String
  isHidden     Boolean  @default(false) @map("is_hidden")
  hiddenReason String?  @map("hidden_reason")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityId, createdAt])
  @@index([createdAt])
  @@map("entity_chat_messages")
  @@schema("chat")
}
