model GameParty {
  id            String              @id @default(uuid()) @db.Uuid
  vertical      String              @db.VarChar(32)
  name          String              @db.VarChar(80)
  slug          String              @db.VarChar(120)
  ownerUserId   String              @map("owner_user_id") @db.Uuid
  kind          GamePartyKind       @default(TEAM)
  visibility    GamePartyVisibility @default(PUBLIC)
  joinMode      GamePartyJoinMode   @default(CONFIRM) @map("join_mode")
  maxMembers    Int                 @default(5) @map("max_members")
  expiresAt     DateTime?           @map("expires_at") @db.Timestamptz(6)
  discordChannelId String?          @map("discord_channel_id") @db.VarChar(32)
  discordInviteUrl String?          @map("discord_invite_url") @db.VarChar(256)
  discordVoiceCreatedAt DateTime?   @map("discord_voice_created_at") @db.Timestamptz(6)
  discordVoiceExpiresAt DateTime?   @map("discord_voice_expires_at") @db.Timestamptz(6)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  owner         User                @relation("GamePartyOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members       GamePartyMember[]
  invites       GamePartyInvite[]
  chatMessages  GamePartyChatMessage[]

  @@unique([vertical, slug])
  @@index([ownerUserId])
  @@index([vertical, createdAt(sort: Desc)])
  @@index([vertical, kind, expiresAt])
  @@map("game_parties")
  @@schema("social")
}

model GamePartyMember {
  id           String              @id @default(uuid()) @db.Uuid
  partyId      String              @map("party_id") @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  role         GamePartyMemberRole @default(MEMBER)
  /// Dota lane position 1-5; null until the member claims a slot.
  positionRole String?             @map("position_role")
  joinedAt     DateTime            @default(now()) @map("joined_at") @db.Timestamptz(6)
  party        GameParty           @relation(fields: [partyId], references: [id], onDelete: Cascade)
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([partyId, userId])
  @@index([userId])
  @@map("game_party_members")
  @@schema("social")
}

model GamePartyInvite {
  id            String                @id @default(uuid()) @db.Uuid
  partyId       String                @map("party_id") @db.Uuid
  inviterUserId String                @map("inviter_user_id") @db.Uuid
  inviteeUserId String                @map("invitee_user_id") @db.Uuid
  kind          GamePartyInviteKind   @default(INVITE)
  /// Lane position offered/requested with this invite.
  positionRole  String?               @map("position_role")
  status        GamePartyInviteStatus @default(PENDING)
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  party         GameParty             @relation(fields: [partyId], references: [id], onDelete: Cascade)
  inviter       User                  @relation("GamePartyInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  invitee       User                  @relation("GamePartyInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  @@index([partyId, status])
  @@index([inviteeUserId, status])
  @@index([inviterUserId])
  @@map("game_party_invites")
  @@schema("social")
}

