generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  moduleFormat        = "esm"
  importFileExtension = "js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "chat", "community", "contributions", "entities", "growth", "ratings", "reviews", "social", "tops", "users", "reputation"]
}

model User {
  id             String             @id @default(uuid()) @db.Uuid
  email          String?            @unique
  username       String?            @unique
  displayName    String             @map("display_name")
  avatarUrl      String?            @map("avatar_url")
  role           UserRole           @default(USER)
  status         String             @default("active")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  authIdentities     UserAuthIdentity[]
  entityChatMessages EntityChatMessage[]
  activityEvents     ActivityEvent[]
  contributionSnapshot UserContributionSnapshot?
  contributionBadges   UserContributionBadge[]
  expertiseSnapshots   UserExpertiseSnapshot[]
  curatorRankSnapshots UserCuratorRankSnapshot[]
  spotlightCreditBalance SpotlightCreditBalance?
  spotlightCreditLedger  SpotlightCreditLedger[]
  spotlightPlacements    SpotlightPlacement[]
  spotlightPlacementEvents SpotlightPlacementEvent[]
  communityRecommendations CommunityRecommendation[]
  recommendationEndorsements RecommendationEndorsement[]
  friendshipsRequested   UserFriendship[] @relation("FriendshipRequester")
  friendshipsReceived    UserFriendship[] @relation("FriendshipAddressee")
  ownedGameParties       GameParty[]      @relation("GamePartyOwner")
  gamePartyMemberships   GamePartyMember[]
  gamePartyInvitesSent   GamePartyInvite[] @relation("GamePartyInviter")
  gamePartyInvitesReceived GamePartyInvite[] @relation("GamePartyInvitee")
  gamePartyChatMessages  GamePartyChatMessage[]
  accountRecoveryTokens  AccountRecoveryToken[]

  @@map("users")
  @@schema("users")
}

enum UserRole {
  USER
  ADMIN

  @@map("user_role")
  @@schema("users")
}

model UserAuthIdentity {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String
  providerUserId String   @map("provider_user_id")
  passwordHash   String?  @map("password_hash")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("user_auth_identities")
  @@schema("auth")
}

model AccountRecoveryToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  consumedAt  DateTime? @map("consumed_at") @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account_recovery_tokens")
  @@schema("auth")
}

enum EntityType {
  website
  page
  video
  channel
  repository
  organization
  product
  book
  movie
  game
  company
  person
  place
  other

  @@map("entity_type")
  @@schema("entities")
}

enum EntityVisibility {
  ACTIVE
  HIDDEN

  @@map("entity_visibility")
  @@schema("entities")
}

enum EntityMediaType {
  LOGO
  IMAGE
  COVER

  @@map("entity_media_type")
  @@schema("entities")
}

enum EntityMediaSource {
  MANUAL
  CONTRIBUTION
  FAVICON
  OG_IMAGE
  MIGRATION

  @@map("entity_media_source")
  @@schema("entities")
}

model Entity {
  id           String           @id @default(uuid()) @db.Uuid
  title        String
  slug         String           @unique
  type         EntityType
  visibility   EntityVisibility @default(ACTIVE)
  description  String?
  logoUrl      String?          @map("logo_url")
  canonicalUrl String?          @unique @map("canonical_url")
  parentId     String?          @map("parent_id") @db.Uuid
  createdBy    String?          @map("created_by") @db.Uuid
  ownerUserId  String?          @unique @map("owner_user_id") @db.Uuid
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  parent       Entity?          @relation("EntityTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     Entity[]         @relation("EntityTree")
  clusterMember EntityClusterMember?
  media        EntityMedia[]
  attributes   EntityAttribute[]
  qualityConfirmations EntityQualityConfirmation[]

  @@index([type])
  @@index([parentId])
  @@index([createdBy])
  @@index([ownerUserId])
  @@index([visibility])
  @@map("entities")
  @@schema("entities")
}

model EntityAttribute {
  entityId  String   @map("entity_id") @db.Uuid
  key       String   @db.VarChar(64)
  value     String   @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@id([entityId, key])
  @@index([key, value])
  @@map("entity_attributes")
  @@schema("entities")
}

model EntityQualityConfirmation {
  id           String   @id @default(uuid()) @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid
  qualityKey   String   @map("quality_key") @db.VarChar(64)
  confirmerKey String   @map("confirmer_key") @db.VarChar(128)
  voterUserId  String?  @map("voter_user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  entity       Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, qualityKey, confirmerKey])
  @@index([entityId])
  @@index([confirmerKey])
  @@map("entity_quality_confirmations")
  @@schema("entities")
}

model EntityMedia {
  id         String            @id @default(uuid()) @db.Uuid
  entityId   String            @map("entity_id") @db.Uuid
  type       EntityMediaType
  source     EntityMediaSource
  url        String            @db.VarChar(2048)
  trustScore Decimal           @map("trust_score") @db.Decimal(4, 3)
  createdAt  DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  entity     Entity            @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([entityId, type, source])
  @@index([entityId, type])
  @@map("entity_media")
  @@schema("entities")
}

model EntityCluster {
  id        String                @id @default(uuid()) @db.Uuid
  createdAt DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  members   EntityClusterMember[]

  @@map("entity_clusters")
  @@schema("entities")
}

model EntityClusterMember {
  id        String        @id @default(uuid()) @db.Uuid
  clusterId String        @map("cluster_id") @db.Uuid
  entityId  String        @unique @map("entity_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  cluster   EntityCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  entity    Entity        @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([clusterId])
  @@map("entity_cluster_members")
  @@schema("entities")
}

enum ContributionType {
  UPDATE_NAME
  UPDATE_URL
  UPDATE_DESCRIPTION
  UPDATE_LOGO
  UPDATE_TYPE
  MERGE_ENTITY
  LINK_ENTITY
  UNLINK_ENTITY

  @@map("contribution_type")
  @@schema("contributions")
}

enum ContributionStatus {
  PENDING
  APPROVED
  REJECTED
  APPLIED
  SUPERSEDED

  @@map("contribution_status")
  @@schema("contributions")
}

enum ContributionTier {
  AUTO
  MODERATION

  @@map("contribution_tier")
  @@schema("contributions")
}

enum ContributionVoteKind {
  APPROVE
  REJECT

  @@map("contribution_vote_kind")
  @@schema("contributions")
}

enum FieldProvenanceSource {
  community
  author
  system

  @@map("field_provenance_source")
  @@schema("contributions")
}

model EntityContribution {
  id               String             @id @default(uuid()) @db.Uuid
  entityId         String             @map("entity_id") @db.Uuid
  authorId         String             @map("author_id") @db.Uuid
  type             ContributionType
  payload          Json
  status           ContributionStatus @default(PENDING)
  tier             ContributionTier
  approvalsWeight  Decimal            @default(0) @map("approvals_weight") @db.Decimal(8, 3)
  rejectionsWeight Decimal            @default(0) @map("rejections_weight") @db.Decimal(8, 3)
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt       DateTime?          @map("resolved_at") @db.Timestamptz(6)
  appliedAt        DateTime?          @map("applied_at") @db.Timestamptz(6)
  resolvedBy       String?            @map("resolved_by") @db.Uuid
  votes            ContributionVote[]

  @@index([entityId, status])
  @@index([authorId])
  @@index([type, status])
  @@map("entity_contributions")
  @@schema("contributions")
}

model ContributionVote {
  id             String               @id @default(uuid()) @db.Uuid
  contributionId String               @map("contribution_id") @db.Uuid
  voterId        String               @map("voter_id") @db.Uuid
  kind           ContributionVoteKind
  weight         Decimal              @db.Decimal(4, 3)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  contribution   EntityContribution   @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  @@unique([contributionId, voterId])
  @@index([voterId])
  @@map("contribution_votes")
  @@schema("contributions")
}

model ContributionPolicy {
  type              ContributionType @id
  tier              ContributionTier
  baseApproveWeight Decimal          @map("base_approve_weight") @db.Decimal(6, 3)
  baseRejectWeight  Decimal          @map("base_reject_weight") @db.Decimal(6, 3)
  activityScale     Boolean          @default(false) @map("activity_scale")
  minUniqueVoters   Int              @default(2) @map("min_unique_voters")
  cooldownHours     Int              @default(0) @map("cooldown_hours")

  @@map("contribution_policies")
  @@schema("contributions")
}

model EntityFieldProvenance {
  entityId       String                @map("entity_id") @db.Uuid
  field          String
  source         FieldProvenanceSource
  contributionId String?               @map("contribution_id") @db.Uuid
  confirmedAt    DateTime              @map("confirmed_at") @db.Timestamptz(6)
  votersCount    Int                   @default(0) @map("voters_count")

  @@id([entityId, field])
  @@map("entity_field_provenance")
  @@schema("contributions")
}

model Rating {
  id        String   @id @default(uuid()) @db.Uuid
  entityId  String   @map("entity_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  score     Int      @db.SmallInt
  source    String   @default("web")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([entityId, userId])
  @@index([entityId])
  @@index([userId])
  @@map("ratings")
  @@schema("ratings")
}

model RatingAggregate {
  entityId      String   @id @map("entity_id") @db.Uuid
  avgScore      Decimal  @default(0) @map("avg_score") @db.Decimal(3, 2)
  votesCount    Int      @default(0) @map("votes_count")
  distribution1 Int      @default(0) @map("distribution_1")
  distribution2 Int      @default(0) @map("distribution_2")
  distribution3 Int      @default(0) @map("distribution_3")
  distribution4 Int      @default(0) @map("distribution_4")
  distribution5 Int      @default(0) @map("distribution_5")
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("rating_aggregates")
  @@schema("ratings")
}

enum ReviewVisibility {
  ACTIVE
  HIDDEN

  @@map("review_visibility")
  @@schema("reviews")
}

model Review {
  id         String           @id @default(uuid()) @db.Uuid
  entityId   String           @map("entity_id") @db.Uuid
  authorId   String           @map("author_id") @db.Uuid
  locale     String           @default("ru")
  text       String
  visibility ReviewVisibility @default(ACTIVE)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  votes                  ReviewVote[]
  communityRecommendations CommunityRecommendation[]

  @@unique([authorId, entityId, locale])
  @@index([entityId])
  @@index([entityId, locale])
  @@index([authorId])
  @@index([visibility])
  @@map("reviews")
  @@schema("reviews")
}

model ReviewVote {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @map("review_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
  @@map("review_votes")
  @@schema("reviews")
}

model UserBehaviorMetrics {
  userId                String    @id @map("user_id") @db.Uuid
  totalRatings          Int       @default(0) @map("total_ratings")
  uniqueEntityCount     Int       @default(0) @map("unique_entity_count")
  uniqueEntityTypeCount Int       @default(0) @map("unique_entity_type_count")
  uniqueRootDomainCount Int       @default(0) @map("unique_root_domain_count")
  score1Count           Int       @default(0) @map("score_1_count")
  score2Count           Int       @default(0) @map("score_2_count")
  score3Count           Int       @default(0) @map("score_3_count")
  score4Count           Int       @default(0) @map("score_4_count")
  score5Count           Int       @default(0) @map("score_5_count")
  firstRatingAt         DateTime? @map("first_rating_at") @db.Timestamptz(6)
  lastRatingAt          DateTime? @map("last_rating_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("user_behavior_metrics")
  @@schema("reputation")
}

model UserActivityDaily {
  userId       String   @map("user_id") @db.Uuid
  activityDate DateTime @map("activity_date") @db.Date
  ratingCount  Int      @default(0) @map("rating_count")

  @@id([userId, activityDate])
  @@index([userId, activityDate(sort: Desc)])
  @@map("user_activity_daily")
  @@schema("reputation")
}

model UserActivityHourly {
  userId             String   @map("user_id") @db.Uuid
  activityHour       DateTime @map("activity_hour") @db.Timestamptz(6)
  ratingCreatedCount Int      @default(0) @map("rating_created_count")
  ratingUpdatedCount Int      @default(0) @map("rating_updated_count")

  @@id([userId, activityHour])
  @@index([userId, activityHour(sort: Desc)])
  @@map("user_activity_hourly")
  @@schema("reputation")
}

model UserEntityStats {
  userId      String   @map("user_id") @db.Uuid
  entityId    String   @map("entity_id") @db.Uuid
  ratingCount Int      @default(0) @map("rating_count")
  lastRatedAt DateTime @map("last_rated_at") @db.Timestamptz(6)

  @@id([userId, entityId])
  @@index([userId, ratingCount(sort: Desc)])
  @@map("user_entity_stats")
  @@schema("reputation")
}

model UserEntityTypeStats {
  userId            String @map("user_id") @db.Uuid
  entityType        String @map("entity_type")
  parentContextType String @default("__root__") @map("parent_context_type")
  ratingCount       Int    @default(0) @map("rating_count")

  @@id([userId, entityType, parentContextType])
  @@map("user_entity_type_stats")
  @@schema("reputation")
}

model UserRootDomainStats {
  userId      String @map("user_id") @db.Uuid
  rootDomain  String @map("root_domain")
  ratingCount Int    @default(0) @map("rating_count")

  @@id([userId, rootDomain])
  @@map("user_root_domain_stats")
  @@schema("reputation")
}

model UserTrustProfile {
  userId             String   @id @map("user_id") @db.Uuid
  trustScore         Decimal  @map("trust_score") @db.Decimal(4, 3)
  diversityScore     Decimal  @map("diversity_score") @db.Decimal(4, 3)
  coverageScore      Decimal  @map("coverage_score") @db.Decimal(4, 3)
  stabilityScore     Decimal  @map("stability_score") @db.Decimal(4, 3)
  consensusScore     Decimal  @map("consensus_score") @db.Decimal(4, 3)
  accountAgeBonus    Decimal  @map("account_age_bonus") @db.Decimal(4, 3)
  anomalyPenalty     Decimal  @default(0) @map("anomaly_penalty") @db.Decimal(4, 3)
  calculationVersion Int      @map("calculation_version")
  calculatedAt       DateTime @map("calculated_at") @db.Timestamptz(6)

  @@map("user_trust_profiles")
  @@schema("reputation")
}

model VoteWeightSnapshot {
  id                 String   @id @default(uuid()) @db.Uuid
  ratingId           String   @unique @map("rating_id") @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  entityId           String   @map("entity_id") @db.Uuid
  score              Int      @db.SmallInt
  voteWeight         Decimal  @map("vote_weight") @db.Decimal(4, 3)
  weightFactors      Json     @default("{}") @map("weight_factors")
  calculationVersion Int      @map("calculation_version")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityId])
  @@index([userId])
  @@map("vote_weight_snapshots")
  @@schema("reputation")
}

model EntityAnomalyMetrics {
  entityId         String    @id @map("entity_id") @db.Uuid
  anomalyScore     Decimal   @default(0) @map("anomaly_score") @db.Decimal(4, 3)
  burstScore       Decimal   @default(0) @map("burst_score") @db.Decimal(4, 3)
  syncScore        Decimal   @default(0) @map("sync_score") @db.Decimal(4, 3)
  clusterScore     Decimal   @default(0) @map("cluster_score") @db.Decimal(4, 3)
  recentBurstCount Int       @default(0) @map("recent_burst_count")
  lastAnomalyAt    DateTime? @map("last_anomaly_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("entity_anomaly_metrics")
  @@schema("reputation")
}

model EntityActivityHourly {
  entityId     String   @map("entity_id") @db.Uuid
  activityHour DateTime @map("activity_hour") @db.Timestamptz(6)
  ratingCount  Int      @default(0) @map("rating_count")

  @@id([entityId, activityHour])
  @@map("entity_activity_hourly")
  @@schema("reputation")
}

model EntityConfidenceProfile {
  entityId             String   @id @map("entity_id") @db.Uuid
  confidenceScore      Decimal  @map("confidence_score") @db.Decimal(4, 3)
  dataReliability      Decimal? @map("data_reliability") @db.Decimal(4, 3)
  manipulationRisk     Decimal? @map("manipulation_risk") @db.Decimal(4, 3)
  effectiveVoteMass    Decimal  @default(0) @map("effective_vote_mass") @db.Decimal(10, 2)
  uniqueRatersCount    Int      @default(0) @map("unique_raters_count")
  activityDurationDays Int      @default(0) @map("activity_duration_days")
  scoreVariance        Decimal? @map("score_variance") @db.Decimal(6, 4)
  anomalyScore         Decimal  @default(0) @map("anomaly_score") @db.Decimal(4, 3)
  calculationVersion   Int      @map("calculation_version")
  explanation          Json     @default("[]")
  calculatedAt         DateTime @map("calculated_at") @db.Timestamptz(6)

  @@map("entity_confidence_profiles")
  @@schema("reputation")
}

model UserCoordinationCluster {
  id           String                  @id @default(uuid()) @db.Uuid
  memberCount  Int                     @map("member_count")
  overlapScore Decimal                 @map("overlap_score") @db.Decimal(4, 3)
  detectedAt   DateTime                @default(now()) @map("detected_at") @db.Timestamptz(6)
  members      UserClusterMembership[]

  @@map("user_coordination_clusters")
  @@schema("reputation")
}

model UserClusterMembership {
  clusterId String                  @map("cluster_id") @db.Uuid
  userId    String                  @map("user_id") @db.Uuid
  joinedAt  DateTime                @default(now()) @map("joined_at") @db.Timestamptz(6)
  cluster   UserCoordinationCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@id([clusterId, userId])
  @@index([userId])
  @@map("user_cluster_memberships")
  @@schema("reputation")
}

model UserCoordinationScore {
  userId       String   @id @map("user_id") @db.Uuid
  clusterScore Decimal  @map("cluster_score") @db.Decimal(4, 3)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("user_coordination_scores")
  @@schema("reputation")
}

model ReputationEvent {
  id        String   @id @default(uuid()) @db.Uuid
  type      String
  userId    String?  @map("user_id") @db.Uuid
  entityId  String?  @map("entity_id") @db.Uuid
  ratingId  String?  @map("rating_id") @db.Uuid
  payload   Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId, createdAt])
  @@index([entityId, createdAt])
  @@index([type, createdAt])
  @@map("reputation_events")
  @@schema("reputation")
}

model EntityChatMessage {
  id           String   @id @default(uuid()) @db.Uuid
  entityId     String   @map("entity_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  locale       String   @default("ru")
  message      String
  isHidden     Boolean  @default(false) @map("is_hidden")
  hiddenReason String?  @map("hidden_reason")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([entityId, locale, createdAt])
  @@index([createdAt])
  @@map("entity_chat_messages")
  @@schema("chat")
}

model BattleVote {
  id        String   @id @default(uuid()) @db.Uuid
  pairKey   String   @map("pair_key")
  entityId  String   @map("entity_id") @db.Uuid
  voterKey  String   @map("voter_key")
  locale    String   @default("ru")
  userId    String?  @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([pairKey, voterKey, locale])
  @@index([pairKey])
  @@index([pairKey, locale])
  @@map("battle_votes")
  @@schema("growth")
}

enum ContributionLevel {
  newcomer
  contributor
  active_contributor
  curator
  pioneer

  @@map("contribution_level")
  @@schema("community")
}

model ActivityEvent {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  actionType   String   @map("action_type")
  entityId     String?  @map("entity_id") @db.Uuid
  entityType   String?  @map("entity_type")
  categoryId   String?  @map("category_id") @db.Uuid
  targetUserId String?  @map("target_user_id") @db.Uuid
  payload      Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([actionType, createdAt])
  @@index([entityId, createdAt])
  @@map("activity_events")
  @@schema("community")
}

model UserContributionSnapshot {
