# Example only — do NOT put real tokens here (this file is committed).
# Real secrets: root `.env.production` on VPS, or local `.env` (gitignored).

WELCOME_FLOW_BOT_TOKEN=change_me_telegram_bot_token
WELCOME_FLOW_CHANNEL_URL=https://t.me/opinia_official
WELCOME_FLOW_ADMIN_IDS=

# Paths for Docker (default on hosting — leave as-is):
# DB lives in named volume mounted at /data
WELCOME_FLOW_DATABASE_PATH=/data/welcome_flow.db
# Empty = use templates.json baked into the image (/app/templates.json)
WELCOME_FLOW_TEMPLATES_PATH=

# Local without Docker (uncomment if running `python -m bot` on host):
# WELCOME_FLOW_DATABASE_PATH=./data/welcome_flow.db

WELCOME_FLOW_DELAY_MIN=6
WELCOME_FLOW_DELAY_MAX=18
WELCOME_FLOW_COOLDOWN_DAYS=30
WELCOME_FLOW_HOURLY_CAP=40
