# Copy this file to `.env.development` for local development or to `.env.production`
# for deployment-specific values. Do not commit real production secrets.

# Compose
COMPOSE_PROJECT_NAME=reviewo
IMAGE_TAG=local
CI=true
NODE_ENV=development
NODE_IMAGE=node:22-alpine
POSTGRES_IMAGE=postgres:17-alpine
REDIS_IMAGE=redis:8-alpine
MINIO_IMAGE=minio/minio:latest

# Application ports
API_PORT=3000
WEB_PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3001
# Production must include apex + www + games + dota (+ chrome-extension://ID if shipping extension):
# CORS_ALLOWED_ORIGINS=https://opinia.ru,https://www.opinia.ru,https://games.opinia.ru,https://dota.opinia.ru
TRUST_PROXY_HOPS=0

# Web (public; production values are embedded at Next.js build time)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
# Server-side fetches from the web container (Docker): internal API hostname
API_INTERNAL_BASE_URL=http://api:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Chrome Web Store link (optional; CTAs hidden when empty)
NEXT_PUBLIC_EXTENSION_INSTALL_URL=

# Auth
JWT_SECRET=change_me_for_real_environment_jwt_secret_at_least_32_chars
# 7 days
JWT_ACCESS_TOKEN_TTL_SECONDS=604800

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=reviewo
POSTGRES_USER=reviewo
POSTGRES_PASSWORD=change_me_for_real_environment

# Optional: promote an existing user to ADMIN after register (seed)
# ADMIN_EMAIL=admin@example.com

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# Reputation Engine
# Keep false on production until migration + backfill + verification are complete.
REPUTATION_ENGINE_ENABLED=true
# Optional: REPUTATION_REPLAY_CALCULATION_VERSION=2

# MinIO / S3-compatible storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=reviewo
MINIO_ROOT_PASSWORD=change_me_for_real_environment
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=reviewo

# Telegram waitlist bot (long polling, no public port)
WAITLIST_BOT_TOKEN=change_me_telegram_bot_token
WAITLIST_CHANNEL_URL=https://t.me/opinia_official
WAITLIST_SUPPORT_URL=https://t.me/opinia_support
WAITLIST_ADMIN_IDS=
WAITLIST_DATABASE_PATH=/data/waitlist.db

# Google Sheets mirror for games launch waitlist (optional until wired in API)
# From service account JSON: client_email + private_key
# Sheet ID from URL: https://docs.google.com/spreadsheets/d/<GAMES_LAUNCH_SHEET_ID>/edit
# Create two tabs named exactly: Interest and Suggestions
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GAMES_LAUNCH_SHEET_ID=
