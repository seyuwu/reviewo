# Copy this file to `.env.development` for local development or to `.env.production`
# for deployment-specific values. Do not commit real production secrets.

# Compose
COMPOSE_PROJECT_NAME=reviewo
IMAGE_TAG=local
CI=true
NODE_ENV=development
NODE_IMAGE=node:22-alpine
POSTGRES_IMAGE=postgres:17-alpine
REDIS_IMAGE=redis:8-alpine
MINIO_IMAGE=minio/minio:latest

# Application ports
API_PORT=3000
WEB_PORT=3001

# Auth
JWT_SECRET=change_me_for_real_environment_jwt_secret_at_least_32_chars
JWT_ACCESS_TOKEN_TTL_SECONDS=900

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=reviewo
POSTGRES_USER=reviewo
POSTGRES_PASSWORD=change_me_for_real_environment

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MinIO / S3-compatible storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=reviewo
MINIO_ROOT_PASSWORD=change_me_for_real_environment
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_BUCKET=reviewo
